diff --git a/evutil_rand.c b/evutil_rand.c
--- a/evutil_rand.c
+++ b/evutil_rand.c
@@ -195,6 +195,11 @@ void
 evutil_secure_rng_add_bytes(const char *buf, size_t n)
 {
+#if defined(__linux__) && defined(__GLIBC__)
+	(void)buf;
+	(void)n;
+#else
 	arc4random_addrandom((unsigned char*)buf,
 	    n>(size_t)INT_MAX ? INT_MAX : (int)n);
+#endif
 }
